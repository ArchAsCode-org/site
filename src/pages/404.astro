---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — ArchAsCode" description="Page not found.">
	<main class="relative">
		<section class="mx-auto max-w-3xl px-6 py-32 text-center">
			<p class="font-mono text-sm text-indigo-400">404</p>
			<h1 class="mt-4 text-4xl font-bold tracking-tight text-white">Page not found</h1>
			<p class="mt-4 text-zinc-400">This route isn&rsquo;t in the spec.</p>
			<a
				href="/"
				class="mt-8 inline-block rounded-lg bg-indigo-600 px-5 py-3 font-medium text-white transition hover:bg-indigo-500"
				>Back to home</a
			>
		</section>
	</main>
</Layout>
